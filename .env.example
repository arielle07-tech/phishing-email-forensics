# Phishing Email Forensics — Configuration
# Copier ce fichier vers .env et remplir les valeurs

# Provider IA (auto = détection automatique)
AI_PROVIDER=auto

# Google Gemini (recommandé, gratuit)
# GEMINI_API_KEY=AI...
# GEMINI_MODEL=gemini-2.5-flash

# Groq (rapide, gratuit)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (optionnel)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optionnel)
# OPENAI_API_KEY=sk-...

# Ollama local (optionnel)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Integration ticketing (optionnel) ──
# Connecteur : rtir, thehive, jira (vide = mode local uniquement)
# TICKET_CONNECTOR=rtir
# TICKET_URL=http://localhost:8080
# TICKET_USER=root
# TICKET_PASSWORD=password
# TICKET_VERIFY_SSL=false
# TheHive: TICKET_API_KEY=votre_cle_api
# JIRA: TICKET_API_TOKEN=votre_token, TICKET_PROJECT_KEY=SEC
